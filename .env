# =============================================================================
# ENVIRONMENT VARIABLES — Merkezi Yapılandırma Dosyası
# =============================================================================
#
# Bu dosya TÜM servislerin ihtiyaç duyduğu environment variable'ları içerir.
# docker-compose.yml'de env_file: .env olarak referans edilir.
#
# GÜVENLİK UYARILARI:
# 1. Bu dosyayı ASLA Git'e commit etmeyin! (.gitignore'a ekleyin)
# 2. Production şifrelerini burada saklamayın!
# 3. Production'da secret management araçları kullanın:
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Kubernetes Secrets
#    - Docker Secrets (Swarm mode)
#
# Bu dosya sadece LOCAL DEVELOPMENT içindir.
# Production'da .env.example dosyası oluşturup
# gerçek değerleri CI/CD pipeline'ından enjekte edin.

# =============================================================================
# MongoDB Yapılandırması
# =============================================================================

# Root kullanıcı adı — MongoDB ilk başlatıldığında bu kullanıcıyı oluşturur
MONGO_INITDB_ROOT_USERNAME=admin

# Root şifresi — Production'da güçlü, rastgele bir şifre kullanın!
# Örnek güçlü şifre üretmek için: openssl rand -base64 32
MONGO_INITDB_ROOT_PASSWORD=securepassword123

# Uygulama veritabanı adı
MONGO_DB_NAME=TaskManager

# MongoDB host adı — Docker Compose'da service name kullanılır
# 'localhost' DEĞİL 'mongodb' yazıyoruz çünkü:
# Container'lar kendi izole network'lerinde çalışır.
# 'localhost' her zaman container'ın KENDİSİNİ işaret eder.
# 'mongodb' ise Docker DNS tarafından MongoDB container'ının IP'sine çözümlenir.
MONGO_HOST=mongodb

# MongoDB portu
MONGO_PORT=27017

# =============================================================================
# Flask Yapılandırması
# =============================================================================

# Flask SECRET_KEY — Session yönetimi ve CSRF koruması için kullanılır
# Production'da rastgele, uzun bir string olmalıdır!
# Üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-super-secret-key-change-in-production

# Flask ortamı — 'production' veya 'development'
FLASK_ENV=production

# Debug modu — Production'da KESİNLİKLE 0 (kapalı) olmalı!
# Debug açıkken:
# 1. Detaylı hata mesajları görünür (güvenlik riski)
# 2. Kod değişikliklerinde otomatik restart olur (performans)
# 3. Debugger pin ile uzaktan kod çalıştırılabilir (güvenlik riski!)
FLASK_DEBUG=0
